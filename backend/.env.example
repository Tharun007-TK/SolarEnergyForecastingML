# Copy this file to .env and adjust values for your environment.

# SQLAlchemy connection string. SQLite for dev, Postgres URL for prod.
DATABASE_URL=sqlite:///./solarsense.db

# When true, the server seeds 3 demo panels + 14 days of simulated readings
# on first startup. Set to false for real-panel use.
DEMO_MODE=true

# How often the scheduler fetches weather and refreshes expected output / PR.
SCHEDULER_INTERVAL_MINUTES=60

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
